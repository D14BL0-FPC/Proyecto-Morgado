FROM franm88/nginx

RUN apt update && apt install -yq --no-install-recommends \
    curl \
    ca-certificates

# Instalar Node 20 (controlando versión)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt install -y nodejs \
    && npm install -g npm@latest

RUN mkdir -p /root/admin/nodenest
RUN mkdir -p /root/admin/nodenest/proyectos/pokenest
WORKDIR /root/admin/nodenest
COPY ./proyectos/ppokenest/pokenest/ /root/admin/nodenest/proyectos/pokenest

COPY ./dockerfiles/nodejsnest/admin/start.sh .
RUN chmod +x /root/admin/nodenest/start.sh

ENTRYPOINT [ "./start.sh" ]
